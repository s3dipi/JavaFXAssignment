<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.farmingdale.javafxassignment.HelloController"
            prefWidth="800"
            prefHeight="550"
            stylesheets="@styles.css">

    <top>
        <MenuBar>

            <Menu text="File">
                <MenuItem text="New Student"/>
                <MenuItem text="Save Records"/>
                <MenuItem text="Close"/>
            </Menu>

            <Menu text="Edit">
                <MenuItem text="Clear Form"/>
                <MenuItem text="Add Student"/>
                <MenuItem text="Delete Student"/>
                <MenuItem text="Edit Student"/>
            </Menu>

            <Menu text="Theme">
                <MenuItem text="Light mode"/>
                <MenuItem text="Dark mode"/>
            </Menu>

            <Menu text="Help">
                <MenuItem text="Contact Support"/>
            </Menu>

        </MenuBar>
    </top>

    <left>
        <VBox styleClass="left-panel" alignment="TOP_CENTER">
            <ImageView fitWidth="90"
                       fitHeight="90"
                       preserveRatio="true">
                <image>
                    <Image url="@default_profile_pic.jpg"/>
                </image>
            </ImageView>
        </VBox>
    </left>

    <center>
        <TableView fx:id="studentTableView">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="firstNameColumn" text="First Name" prefWidth="120"/>
                <TableColumn fx:id="lastNameColumn" text="Last Name" prefWidth="120"/>
                <TableColumn fx:id="departmentColumn" text="Department" prefWidth="140"/>
                <TableColumn fx:id="majorColumn" text="Major" prefWidth="110"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" styleClass="right-panel">
            <TextField fx:id="firstNameField" promptText="First Name"/>
            <TextField fx:id="lastNameField" promptText="Last Name"/>
            <TextField fx:id="departmentField" promptText="Department"/>
            <TextField fx:id="majorField" promptText="Major"/>
            <TextField fx:id="emailField" promptText="Email"/>
            <TextField fx:id="imageUrlField" promptText="imageURL"/>

            <Region prefHeight="50"/>

            <Button text="Clear" onAction="#clearFields"/>
            <Button text="Add" onAction="#addStudent"/>
            <Button text="Delete" onAction="#deleteStudent"/>
            <Button text="Edit" onAction="#editStudent"/>
        </VBox>
    </right>

    <bottom>
        <Pane styleClass="bottom-bar" prefHeight="35"/>
    </bottom>

</BorderPane>